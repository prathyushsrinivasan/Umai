# Copy to `.env` and fill in real values for local development.
# `.env` is gitignored; this template is committed. Never put real secrets here.

# --- Required ---

# JWT signing key. Backend fails to start if unset.
# Generate one with: openssl rand -base64 48
JWT_SECRET=

# --- Database (override the dev defaults if your setup differs) ---

# Defaults: jdbc:postgresql://localhost:5432/umai, user `umai`, password `umai`.
# DB_URL=jdbc:postgresql://localhost:5432/umai
# DB_USERNAME=umai
DB_PASSWORD=

# --- Optional overrides (see application.yml for full list) ---

# Comma-separated emails promoted to ADMIN at startup (accounts must already exist).
# UMAI_ADMIN_EMAILS=
# JWT_EXPIRES_IN=12h
# CORS_ALLOWED_ORIGINS=http://localhost:5173
# SERVER_PORT=8080
