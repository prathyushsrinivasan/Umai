# Copy this file to `.env` and fill in real values.
#
#   cp .env.example .env
#
# `.env` is git-ignored and must never be committed.
# These values are consumed by docker-compose.yml and passed to the backend.

# ---- PostgreSQL / PostGIS ----
POSTGRES_DB=umai
POSTGRES_USER=umai
# Required. Choose your own value; there is intentionally no default.
POSTGRES_PASSWORD=change-me-locally
# Host port the database is published on.
DB_PORT=5432

# ---- Backend ----
# Host port the API is published on.
BACKEND_PORT=8080
# Comma-separated origins allowed to call the API from a browser.
CORS_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO

# Which Flyway locations to apply.
# Development (default) loads fictional sample restaurants so the app has data
# immediately. PRODUCTION MUST SET THIS TO `classpath:db/migration` ALONE, otherwise
# fictional restaurants are inserted into the live database.
FLYWAY_LOCATIONS=classpath:db/migration,classpath:db/seed

# ---- Authentication ----
# HMAC signing key for JWTs. REQUIRED — the backend refuses to start without it.
# There is deliberately no built-in default: a committed key would be public.
# Generate your own:
#   openssl rand -base64 48
JWT_SECRET=
# How long an access token stays valid (e.g. 30m, 12h, 7d).
JWT_EXPIRES_IN=12h

# Whether user-submitted restaurants are published immediately (true) or held as
# PENDING for moderation (false). Moderation tooling does not exist yet, so
# submissions held as PENDING would not be reviewable.
SUBMISSIONS_AUTO_PUBLISH=true

# Comma-separated emails promoted to ADMIN on startup. The accounts must already be
# registered — this never creates users. Use it to make the first administrator
# instead of running SQL by hand.
UMAI_ADMIN_EMAILS=

# ---- Rate limiting ----
# Per client address, per period. Auth is limited tightly because login is
# brute-forceable; other writes are limited loosely enough not to affect real use.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_ATTEMPTS=10
RATE_LIMIT_WRITE_REQUESTS=60
RATE_LIMIT_PERIOD=1m

# ---- Notes ----
# The frontend has its own environment file: UmaiFrontend/.env.example
# Secrets added in later phases (e.g. the JWT signing key) belong here, not in code.
