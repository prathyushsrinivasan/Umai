# Frontend environment variables.
# Copy to `.env.local` and adjust as needed. Only VITE_-prefixed variables are
# exposed to the browser, so never put secrets here.

# Base URL the browser uses for API calls.
# Leave as /api/v1 to go through the Vite dev proxy (same-origin, no CORS).
VITE_API_BASE_URL=/api/v1

# Where the Vite dev server forwards /api requests.
# Use http://localhost:8080 for a locally run backend, or http://backend:8080
# when the frontend itself runs inside Docker Compose.
VITE_BACKEND_PROXY_TARGET=http://localhost:8080
